{
  "name": "finval",
  "version": "0.1.0",
  "description": "Production-ready financial data validation for fintech infrastructure",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "docs": "typedoc src/index.ts --out docs",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "fintech",
    "validation",
    "finance",
    "typescript",
    "financial-data"
  ],
  "author": "Apostolos Chardalias (Hardalion)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.17",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.46.2",
    "tsup": "^8.5.0",
    "typedoc": "^0.28.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
